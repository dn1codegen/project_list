<nav class="navbar">
  <div class="container">
    <h1 class="navbar-brand">Администрирование</h1>
    <%= button_to 'Выйти', admin_logout_path, method: :delete, class: 'btn btn-sm btn-secondary' %>
  </div>
</nav>

<div class="container">
  <div class="card">
    <h2 class="card-title">Ключи веб-доступа</h2>
    <p style="color: #6c757d; margin-bottom: 15px;">Для доступа к веб-интерфейсу</p>
    <%= form_with url: create_web_access_key_api_keys_path, method: :post, local: true do |f| %>
      <div style="display: flex; gap: 10px; align-items: flex-end;">
        <div class="form-group" style="flex: 1; margin-bottom: 0;">
          <%= text_field_tag :name, nil, required: true, class: 'form-control', placeholder: 'Название ключа' %>
        </div>
        <%= f.submit 'Создать', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>

  <div class="card">
    <% if @web_access_keys.empty? %>
      <p class="no-keys">Нет созданных ключей</p>
    <% else %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Название</th>
              <th>URL</th>
              <th style="text-align: center;">Статус</th>
              <th style="width: 120px;"></th>
            </tr>
          </thead>
          <tbody>
            <% @web_access_keys.each do |key| %>
              <tr>
                <td><%= key.name %></td>
                <td>
                  <code style="font-size: 11px; color: #0066cc; word-break: break-all; cursor: pointer;" onclick="copyToClipboard('http://localhost:3000/projects?token=<%= key.key %>', this)">http://localhost:3000/projects?token=<%= key.key %></code>
                </td>
                <td style="text-align: center;">
                  <%= form_with(url: toggle_api_key_path(key, type: 'web_access'), method: :patch, html: { style: 'display: inline;' }) do |f| %>
                    <label style="position: relative; display: inline-block; width: 44px; height: 24px;">
                      <input type="checkbox" <%= key.active ? 'checked' : '' %> onchange="this.form.submit()" style="opacity: 0; width: 0; height: 0; position: absolute;">
                      <span style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: <%= key.active ? '#28a745' : '#ccc' %>; transition: .3s; border-radius: 24px;">
                        <span style="position: absolute; content: ''; height: 18px; width: 18px; left: <%= key.active ? '22px' : '3px' %>; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%;"></span>
                      </span>
                    </label>
                  <% end %>
                </td>
                <td>
                  <div style="display: flex; gap: 5px;">
                    <%= link_to 'Статистика', link_stats_path(key.id), class: 'btn btn-sm btn-secondary' %>
                    <%= button_to 'Удалить', destroy_web_access_key_api_key_path(key), method: :delete, data: { confirm: 'Вы уверены?' }, class: 'btn btn-sm btn-danger' %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <div class="card" style="margin-top: 30px;">
    <h2 class="card-title">Ключи для проектов</h2>
    <p style="color: #6c757d; margin-bottom: 15px;">Для отправки файлов через send.rb</p>
    <%= form_with url: create_project_key_api_keys_path, method: :post, local: true do |f| %>
      <div style="display: flex; gap: 10px; align-items: flex-end;">
        <div class="form-group" style="flex: 1; margin-bottom: 0;">
          <%= text_field_tag :name, nil, required: true, class: 'form-control', placeholder: 'Название ключа' %>
        </div>
        <%= f.submit 'Создать', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>

  <div class="card">
    <% if @project_keys.empty? %>
      <p class="no-keys">Нет созданных ключей</p>
    <% else %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Название</th>
              <th>Ключ</th>
              <th style="text-align: center;">Статус</th>
              <th style="width: 80px;"></th>
            </tr>
          </thead>
          <tbody>
            <% @project_keys.each do |key| %>
              <tr>
                <td><%= key.name %></td>
                <td><code style="font-size: 11px; word-break: break-all; cursor: pointer;" onclick="copyToClipboard('<%= key.key %>', this)"><%= key.key %></code></td>
                <td style="text-align: center;">
                  <%= form_with(url: toggle_api_key_path(key, type: 'project'), method: :patch, html: { style: 'display: inline;' }) do |f| %>
                    <label style="position: relative; display: inline-block; width: 44px; height: 24px;">
                      <input type="checkbox" <%= key.active ? 'checked' : '' %> onchange="this.form.submit()" style="opacity: 0; width: 0; height: 0; position: absolute;">
                      <span style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: <%= key.active ? '#28a745' : '#ccc' %>; transition: .3s; border-radius: 24px;">
                        <span style="position: absolute; content: ''; height: 18px; width: 18px; left: <%= key.active ? '22px' : '3px' %>; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%;"></span>
                      </span>
                    </label>
                  <% end %>
                </td>
                <td>
                  <%= button_to 'Удалить', destroy_project_key_api_key_path(key), method: :delete, data: { confirm: 'Вы уверены?' }, class: 'btn btn-sm btn-danger' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<script>
function copyToClipboard(text, element) {
  navigator.clipboard.writeText(text).then(function() {
    var originalColor = element.style.color;
    element.style.color = '#28a745';
    element.textContent = 'Скопировано!';
    setTimeout(function() {
      element.style.color = originalColor;
      element.textContent = text;
    }, 1000);
  });
}
</script>
