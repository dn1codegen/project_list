<nav class="navbar">
  <div class="container">
    <h1 class="navbar-brand">Настройки админа</h1>
    <%= link_to '← К Админке', admin_dashboard_path, class: 'btn btn-sm btn-light' %>
  </div>
</nav>

<div class="container">
  <div class="card">
    <h2 class="card-title">Сменить логин и пароль</h2>
    <%= form_with(model: current_admin, url: admin_settings_path, method: :patch, local: true) do |f| %>
      <% if current_admin.errors.any? %>
        <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 5px; padding: 15px; margin-bottom: 20px;">
          <ul style="margin: 0; padding-left: 20px;">
            <% current_admin.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :email, 'Email (логин)' %>
        <%= f.email_field :email, required: true, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :password, 'Новый пароль' %>
        <%= f.password_field :password, class: 'form-control', placeholder: 'Оставьте пустым, если не хотите менять' %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, 'Подтверждение пароля' %>
        <%= f.password_field :password_confirmation, class: 'form-control' %>
      </div>

      <%= f.submit 'Сохранить', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>
