<nav class="navbar">
  <div class="container">
    <h1 class="navbar-brand">Администрирование</h1>
  </div>
</nav>

<div class="container">
  <div class="card" style="max-width: 400px; margin: 50px auto;">
    <h2 class="card-title">Вход для администратора</h2>
    <%= form_with url: admin_login_path, method: :post, local: true do |f| %>
      <div class="form-group">
        <%= label_tag :email, 'Email' %>
        <%= email_field_tag :email, nil, required: true, class: 'form-control', placeholder: 'admin@example.com' %>
      </div>
      <div class="form-group">
        <%= label_tag :password, 'Пароль' %>
        <%= password_field_tag :password, nil, required: true, class: 'form-control', placeholder: 'Введите пароль' %>
      </div>
      <div class="form-group">
        <%= check_box_tag :remember_me, '1', false, id: 'remember_me' %>
        <%= label_tag :remember_me, 'Сохранить сессию' %>
      </div>
      <%= f.submit 'Войти', class: 'btn btn-primary', style: 'width: 100%;' %>
    <% end %>
  </div>
</div>
